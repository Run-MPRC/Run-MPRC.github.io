# Non-secret Functions parameters for local/staging configuration.
# Production values must be environment-scoped and validated. Do not copy this
# file to production without following OPERATIONS_RUNBOOK.md.

# CONFIG-001A accepts only this explicit matrix:
# local = loopback origin + Stripe test mode
# test = HTTPS .test origin + Stripe test mode
# staging = https://dev.runmprc.com + Stripe test mode
# production = https://runmprc.com + Stripe live mode
# There is no production-origin fallback.
# COMMERCE_ENABLED is a deploy-time ceiling for new commerce. Keep it false.
# The separate server-only runtime control also defaults to disabled.
ENVIRONMENT_NAME=local
SITE_ORIGIN=http://localhost:3000
STRIPE_LIVEMODE_EXPECTED=false
COMMERCE_ENABLED=false

# Legacy compatibility only. Sensitive callable functions must migrate to the
# native Firebase `enforceAppCheck` runtime option before live commerce.
ENFORCE_APP_CHECK=false

{
  "name": "functions",
  "description": "Cloud Functions for Firebase - MPRC Backend",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "deploy:prod": "firebase deploy --only functions --project production",
    "logs": "firebase functions:log",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "firebase emulators:exec --only firestore,auth 'npm run test:run'",
    "test:run": "jest"
  },
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.6.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "firebase-functions-test": "^3.1.0",
    "jest": "^29.7.0"
  },
  "private": true
}
